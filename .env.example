# Copy to .env.local and fill local values. .env.local is ignored by git.

# OpenAI Secure MCP Tunnel.
CONTROL_PLANE_TUNNEL_ID=tunnel_...
CONTROL_PLANE_API_KEY=

# Local Obsidian vault root. Quote paths that contain spaces.
OBSIDIAN_ROOT="/absolute/path/to/obsidian-vault"

# Optional: set this to a built gateway binary for lower startup overhead.
# If omitted, scripts/run-obsidian-mcp-stdio.sh falls back to go run.
GATEWAY_BIN=

# Optional local runtime paths and tunnel-client knobs.
MCP_GATEWAY_STATE_DIR=
MCP_GATEWAY_TELEMETRY_DB=
TUNNEL_HEALTH_LISTEN_ADDR=127.0.0.1:0
TUNNEL_LOG_FORMAT=json
